{
  "version": 1,
  "_doc": {
    "purpose": "Machine-readable block catalog. Single source for: (1) the LLM's menu when composing a deck-spec, (2) the deck-spec validator, (3) the design-system gallery. Generated/maintained alongside blocks/<id>/template.html and block-catalog.md.",
    "slotTypes": {
      "string": "short single-line text; respect max (chars)",
      "text": "multi-line body copy; respect max (chars)",
      "icon": "a phosphor BOLD icon name without the -bold suffix, e.g. 'trend-up'. Must exist in assets/phosphor-icons/SVGs/bold/",
      "image": "{ query?, prompt?, source?: 'pexels'|'pixabay'|'ai', url?, dims } — filled by the image subsystem; rendered with .img-fill brand-tint",
      "boolean": "true/false toggle",
      "array": "repeated items; honor min/max; each item follows its 'item' schema",
      "enum": "one of 'values'"
    },
    "themes": ["theme-haze", "theme-monday", "theme-day", "theme-sabbath"],
    "rules": "Char limits are the presentation font-floor proxy: if content exceeds max, shorten content — never shrink type. Kickers are optional everywhere kickerSupported=true (omit to render no-kicker). Primary card icons always render in an .icon-badge; watermarks are added by the assembler. See rules.json / SKILL.md."
  },
  "blocks": [
    {
      "id": "cover-hero",
      "purpose": "Opening slide. Giant headline + context pills + tag row + optional hero icon.",
      "defaultTheme": "theme-sabbath",
      "themes": ["theme-haze", "theme-monday", "theme-sabbath"],
      "kickerSupported": true,
      "ref": "1",
