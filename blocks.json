        "headline": { "type": "string", "max": 40, "help": "2-line allowed via <br>" },
        "descender": { "type": "string", "max": 60, "optional": true },
        "subtitle": { "type": "text", "max": 120, "optional": true },
        "pills": { "type": "array", "max": 2, "optional": true, "item": { "type": "string", "max": 24 }, "help": "outline pills, top-right (the kicker)" },
        "tags": { "type": "array", "max": 4, "optional": true, "item": { "type": "string", "max": 28 }, "help": "solid pills, bottom row" },
        "heroIcon": { "type": "icon", "optional": true },
        "logo": { "type": "enum", "values": ["icon_white", "icon_blue"], "optional": true, "help": "defaults to white on dark/haze, blue on light" }
      }
    },
    {
